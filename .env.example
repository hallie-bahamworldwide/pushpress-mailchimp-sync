# PushPress Platform API — Settings > Developer/API in PushPress Core
PUSHPRESS_API_KEY=
PUSHPRESS_COMPANY_ID=

# Mailchimp — Account > Extras > API keys. The datacenter suffix after the
# last "-" in the key (e.g. "us21") is used automatically to build the API URL.
MAILCHIMP_API_KEY=
# Audience/List ID — Audience > Settings > Audience name and defaults
MAILCHIMP_LIST_ID=

# Optional: subscribe status applied to contacts Mailchimp has never seen
# before. Must be one of: subscribed, unsubscribed, pending, transactional.
# Only change this if you understand Mailchimp's consent requirements.
MAILCHIMP_STATUS_IF_NEW=subscribed
